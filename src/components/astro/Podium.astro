---
import { formatScore } from '@utils/scores';

interface PodiumPlace {
  name: string;
  score: number;
  photo: string;
  slug: string;
}

interface Props {
  first: PodiumPlace;
  second: PodiumPlace;
  third: PodiumPlace;
}

const { first, second, third } = Astro.props;
---

<div class="py-12">
  <h2 class="text-center font-display text-3xl font-bold text-indrox-cream mb-12">
    🏆 TOP 3 THIS MONTH
  </h2>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end">
    <!-- Silver (2nd place) -->
    <a href={`/hall-of-fame`} class="group md:order-2 transform hover:scale-105 transition-transform">
      <div class="rank-2-border bg-indrox-bg-card rounded-lg p-6 text-center">
        <div class="mb-4 text-4xl">🥈</div>
        <div class="w-24 h-24 mx-auto mb-4 rounded-full overflow-hidden border-2 border-indrox-silver">
          <img src={second.photo} alt={second.name} class="w-full h-full object-cover" loading="lazy" />
        </div>
        <h3 class="font-bold text-lg text-indrox-cream group-hover:text-indrox-silver transition-colors mb-1">
          {second.name}
        </h3>
        <div class="text-2xl font-bold text-indrox-silver">{formatScore(second.score)}</div>
        <div class="text-xs text-indrox-cream/60">points</div>
      </div>
    </a>

    <!-- Gold (1st place) -->
    <a href={`/hall-of-fame`} class="group md:order-1">
      <div class="rank-1-border bg-gradient-to-b from-indrox-gold/10 to-indrox-bg-card rounded-lg p-8 text-center transform hover:scale-110 transition-transform">
        <div class="mb-4 text-5xl animate-bounce">👑</div>
        <div class="w-28 h-28 mx-auto mb-4 rounded-full overflow-hidden border-4 border-indrox-gold shadow-lg shadow-indrox-gold/50 animate-pulse-gold-shadow">
          <img src={first.photo} alt={first.name} class="w-full h-full object-cover" loading="lazy" />
        </div>
        <h3 class="font-display text-2xl font-bold text-indrox-cream group-hover:text-indrox-gold transition-colors mb-2">
          {first.name}
        </h3>
        <div class="text-3xl font-bold text-indrox-gold">{formatScore(first.score)}</div>
        <div class="text-sm text-indrox-cream/60 font-semibold">LEGEND</div>
      </div>
    </a>

    <!-- Bronze (3rd place) -->
    <a href={`/hall-of-fame`} class="group md:order-3 transform hover:scale-105 transition-transform">
      <div class="rank-3-border bg-indrox-bg-card rounded-lg p-6 text-center">
        <div class="mb-4 text-4xl">🥉</div>
        <div class="w-24 h-24 mx-auto mb-4 rounded-full overflow-hidden border-2 border-indrox-bronze">
          <img src={third.photo} alt={third.name} class="w-full h-full object-cover" loading="lazy" />
        </div>
        <h3 class="font-bold text-lg text-indrox-cream group-hover:text-indrox-bronze transition-colors mb-1">
          {third.name}
        </h3>
        <div class="text-2xl font-bold text-indrox-bronze">{formatScore(third.score)}</div>
        <div class="text-xs text-indrox-cream/60">points</div>
      </div>
    </a>
  </div>
</div>
