---
import { getScoreColorClass, getScorePercentage } from '@utils/scores';

interface Props {
  label: string;
  score: number;
  maxScore?: number;
  color?: 'gold' | 'purple' | 'silver';
}

const { label, score, maxScore = 10, color = 'purple' } = Astro.props;

const percentage = getScorePercentage(score);
const colorClass = getScoreColorClass(score);

let colorTheme = '';
if (color === 'gold') {
  colorTheme = 'bg-indrox-gold';
} else if (color === 'silver') {
  colorTheme = 'bg-indrox-silver';
} else {
  colorTheme = 'bg-indrox-purple';
}
---

<div class="w-full">
  <div class="flex items-center justify-between mb-2">
    <label class="text-sm font-medium text-indrox-cream">{label}</label>
    <span class="text-sm font-bold text-indrox-gold">{score.toFixed(1)}/{maxScore}</span>
  </div>
  <div class="w-full h-2 bg-indrox-bg-card rounded-full overflow-hidden">
    <div
      class={`h-full rounded-full transition-all duration-500 ${colorTheme}`}
      style={`width: ${percentage}%`}
    ></div>
  </div>
</div>
