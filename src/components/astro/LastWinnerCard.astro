---
interface Props {
  presenterName: string;
  presenterRole: string;
  presenterPhoto: string;
  projectTitle: string;
  totalScore: number;
  landingUrl?: string;
}

const {
  presenterName,
  presenterRole,
  presenterPhoto,
  projectTitle,
  totalScore,
  landingUrl,
} = Astro.props;
---

<section class="w-full max-w-6xl mx-auto py-20 px-6 sm:px-8">
  <div class="mb-14 flex flex-col items-center text-center reveal">
    <div
      class="font-display text-sm tracking-[3px] text-indrox-purple-light uppercase mb-3 font-bold"
    >
      Semana anterior
    </div>
    <h2
      class="font-display text-[clamp(2rem,4.5vw,3.25rem)] leading-[1.1] mb-5 text-indrox-cream font-extrabold"
    >
      El campeón
    </h2>
  </div>

  <div
    class="grid grid-cols-1 md:grid-cols-[auto_1fr] gap-10 items-center max-w-[750px] mx-auto rounded-[18px] bg-gradient-to-b from-[#FFD700]/10 to-[#160E22] p-10 relative border-2 border-transparent bg-clip-padding before:content-[''] before:absolute before:-inset-[2px] before:rounded-[inherit] before:bg-[linear-gradient(135deg,#FFD700,#FFA500,#FFD700,#FFEC6E,#FFD700)] before:bg-[length:300%_300%] before:animate-[shimmer-gold_3s_linear_infinite] before:-z-10 text-center md:text-left reveal"
  >
    <div class="text-center shrink-0 mx-auto md:mx-0">
      <div class="text-[3rem] mb-5 block">🏆</div>
      <img
        src={presenterPhoto}
        alt={presenterName}
        class="w-[140px] h-[140px] rounded-full object-cover border-[4px] border-[#FFD700] shadow-[0_0_40px_rgba(255,215,0,0.5)]"
        loading="lazy"
      />
    </div>
    <div>
      <p
        class="text-[#FFD700] text-[0.8rem] mb-3 tracking-[1.5px] uppercase font-bold"
      >
        Ganador de la semana
      </p>
      <h3
        class="text-[2rem] font-display mb-2 font-bold text-indrox-cream leading-tight"
      >
        {presenterName}
      </h3>
      <p class="text-indrox-purple-light mb-6 text-[0.95rem] font-medium">
        {presenterRole}
      </p>
      <div
        class="bg-[#FFD700]/10 border-[1.5px] border-[#FFD700]/25 rounded-[14px] p-5 mb-6 text-center md:text-left"
      >
        <p
          class="text-[0.8rem] text-indrox-cream/60 mb-2 tracking-[1px] uppercase font-bold"
        >
          Proyecto ganador
        </p>
        <p class="font-bold text-indrox-cream mb-3 text-[1.05rem] leading-snug">
          {projectTitle}
        </p>
        <p class="text-[#FFD700] font-extrabold text-[1.1rem]">
          {totalScore.toFixed(1)}/30 puntos
        </p>
      </div>
      {
        landingUrl && (
          <a
            href={landingUrl}
            target="_blank"
            class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-full font-body text-[0.95rem] font-semibold text-white no-underline transition-all duration-300 bg-gradient-to-br from-indrox-purple to-indrox-purple-dark shadow-[0_4px_20px_rgba(144,0,255,0.3)] hover:-translate-y-0.5 hover:shadow-[0_8px_32px_rgba(144,0,255,0.45)] w-full sm:w-auto"
          >
            Ver proyecto →
          </a>
        )
      }
    </div>
  </div>
</section>
