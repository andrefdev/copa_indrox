---
import { formatDateSpanish } from '@utils/dates';
import { formatScore } from '@utils/scores';

interface Props {
  presenterName: string;
  presenterRole: string;
  presenterPhoto: string;
  projectTitle: string;
  totalScore: number;
  landingUrl?: string;
  date: Date;
}

const { presenterName, presenterRole, presenterPhoto, projectTitle, totalScore, landingUrl, date } = Astro.props;
---

<section class="py-16 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-center font-display text-3xl font-bold text-indrox-cream mb-12">
      LAST WEEK'S CHAMPION
    </h2>

    <div class="rank-1-border bg-gradient-to-br from-indrox-gold/15 via-indrox-bg-card to-indrox-purple-dark/10 rounded-xl p-8 max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <div class="text-6xl mb-4">🏆</div>
        <p class="text-indrox-gold font-bold text-lg mb-2">CHAMPION</p>
        <p class="text-indrox-cream/60 text-sm">{formatDateSpanish(date)}</p>
      </div>

      <div class="flex flex-col sm:flex-row items-center gap-8">
        <!-- Photo -->
        <div class="flex-shrink-0">
          <img
            src={presenterPhoto}
            alt={presenterName}
            class="w-40 h-40 rounded-full object-cover border-4 border-indrox-gold shadow-lg shadow-indrox-gold/50 animate-pulse-gold-shadow"
            loading="lazy"
          />
        </div>

        <!-- Info -->
        <div class="flex-1 text-center sm:text-left">
          <h3 class="text-2xl font-bold text-indrox-cream mb-1">{presenterName}</h3>
          <p class="text-indrox-purple mb-6">{presenterRole}</p>

          <div class="bg-indrox-bg-card/50 rounded-lg p-4 border border-indrox-gold/30 mb-6">
            <p class="text-xs text-indrox-cream/60 mb-2">WINNING PROJECT</p>
            <p class="font-bold text-indrox-cream mb-3">{projectTitle}</p>

            {landingUrl && (
              <a
                href={landingUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block px-4 py-2 bg-indrox-purple hover:bg-indrox-purple-light text-white text-sm font-bold rounded transition-colors"
              >
                View Project →
              </a>
            )}
          </div>

          <div class="flex items-center justify-center sm:justify-start gap-4">
            <div class="text-center">
              <div class="text-3xl font-bold text-indrox-gold">{formatScore(totalScore)}</div>
              <p class="text-xs text-indrox-cream/60">points</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
