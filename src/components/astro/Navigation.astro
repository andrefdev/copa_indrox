---
interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

const navItems = [
  { label: "Inicio", href: "/", exact: true },
  { label: "Hall of Fame", href: "/hall-of-fame" },
  { label: "Reglas", href: "/reglas" },
];

function isActive(href: string, exact: boolean = false): boolean {
  if (exact) return currentPath === href;
  return currentPath.startsWith(href);
}
---

<nav
  class="sticky top-0 z-50 bg-[#0E0816]/90 backdrop-blur-md border-b border-indrox-purple/20"
>
  <div
    class="w-full max-w-7xl mx-auto px-6 h-[60px] flex items-center justify-between"
  >
    <a
      href="/"
      class="flex items-center gap-2.5 font-display text-xl font-extrabold text-indrox-cream no-underline tracking-wide transition-colors hover:text-indrox-purple-light"
    >
      <span>🏆</span>
      <span>COPA INDROX</span>
    </a>

    <div class="hidden sm:flex items-center gap-10">
      {
        navItems.map((item) => {
          const active = isActive(item.href, item.exact);
          return (
            <a
              href={item.href}
              class={`relative text-[0.85rem] no-underline transition-colors pb-0.5 ${active ? "text-indrox-cream font-semibold" : "text-[#F1EFE7]/55 font-medium hover:text-indrox-cream"}`}
            >
              {item.label}
              {active && (
                <span class="absolute bottom-[-2px] left-0 right-0 h-[2px] bg-indrox-purple rounded-sm" />
              )}
            </a>
          );
        })
      }
    </div>

    <button
      class="sm:hidden block bg-transparent border-none text-indrox-cream cursor-pointer p-1"
      aria-label="Toggle navigation"
      id="mobile-menu-button"
    >
      <svg
        width="22"
        height="22"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden flex-col gap-1 px-6 pb-4">
    {
      navItems.map((item) => {
        const active = isActive(item.href, item.exact);
        return (
          <a
            href={item.href}
            class={`block px-4 py-2.5 rounded-xl text-sm no-underline transition-colors ${active ? "bg-indrox-purple text-white font-semibold" : "text-[#F1EFE7]/70 font-medium hover:bg-indrox-bg-card hover:text-indrox-cream"}`}
          >
            {item.label}
          </a>
        );
      })
    }
  </div>
</nav>

<script>
  const button = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");

  if (button && menu) {
    button.addEventListener("click", () => {
      menu.classList.toggle("hidden");
      menu.classList.toggle("flex");
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
        menu.classList.remove("flex");
      });
    });
  }
</script>
