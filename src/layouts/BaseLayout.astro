---
import "@styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  canonicalUrl?: string;
}

const {
  title,
  description = "Copa Indrox - Weekly AI-Powered Innovation Competition",
  ogImage = "/og/og-default.png",
  ogType = "website",
  canonicalUrl,
} = Astro.props;

const canonicalURLString = canonicalUrl
  ? new URL(canonicalUrl, Astro.site).toString()
  : new URL(Astro.url.pathname, Astro.site).toString();

const ogImageURL = new URL(ogImage, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURLString} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURLString} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageURL} />

    <!-- Canonical URL -->
    {canonicalURLString && <link rel="canonical" href={canonicalURLString} />}

    <!-- Fonts: Outfit (display) + Sora (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800;900&family=Sora:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Additional metadata -->
    <meta name="theme-color" content="#9000FF" />
    <meta name="robots" content="index, follow" />

    <title>{title}</title>
  </head>
  <body
    class="min-h-screen flex flex-col bg-indrox-bg text-indrox-cream font-body antialiased selection:bg-indrox-purple selection:text-white"
  >
    <main
      class="w-full h-full flex flex-col flex-1 animate-in fade-in duration-500"
    >
      <slot />
    </main>
  </body>
</html>
