---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Navigation from '@components/astro/Navigation.astro';
import HeroSection from '@components/astro/HeroSection.astro';
import { CountdownTimer } from '@components/react/CountdownTimer';
import { getNextMonday } from '@utils/dates';

// Fetch all content
const weeks = await getCollection('weeks');
const participants = await getCollection('participants');

// Sort weeks by date (newest first)
const sortedWeeks = weeks.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Get last winner
const lastWinnerWeek = sortedWeeks.find(w => w.data.isWinner);
const lastWinnerParticipant = lastWinnerWeek
  ? await getEntry('participants', lastWinnerWeek.data.presenter.id)
  : null;

// Get next presenter
const nextMonday = getNextMonday();
const nextWeek = sortedWeeks.find(w => w.data.date >= nextMonday);
const nextPresenter = nextWeek
  ? await getEntry('participants', nextWeek.data.presenter.id)
  : null;

// Get top 3
const topParticipants = [...participants]
  .sort((a, b) => b.data.totalScore - a.data.totalScore)
  .slice(0, 3);
---

<BaseLayout title="Copa Indrox — Innovación con IA">
  <Navigation />

  <!-- ===== HERO ===== -->
