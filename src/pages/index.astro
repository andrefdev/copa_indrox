        <div class="text-[3rem] mb-5 block">🏆</div>
        <h3 class="font-display text-[1.7rem] tracking-[0.5px] mb-2 text-indrox-cream font-bold">Gran Final Indrox</h3>
        <div class="text-[0.75rem] text-indrox-purple-light uppercase tracking-[1.5px] mb-6 font-semibold">Cada trimestre</div>
        <ul class="list-none flex flex-col gap-3 m-0 p-0 text-left">
          <li class="text-indrox-cream/65 text-[0.95rem] pl-7 relative leading-relaxed before:content-['→'] before:absolute before:left-0 before:text-indrox-purple-light before:font-bold">Tu idea se implementa con presupuesto</li>
          <li class="text-indrox-cream/65 text-[0.95rem] pl-7 relative leading-relaxed before:content-['→'] before:absolute before:left-0 before:text-indrox-purple-light before:font-bold">Lideras el mini-proyecto resultante</li>
          <li class="text-indrox-cream/65 text-[0.95rem] pl-7 relative leading-relaxed before:content-['→'] before:absolute before:left-0 before:text-indrox-purple-light before:font-bold">Premio económico premium</li>
