        <div class="relative overflow-hidden group bg-[#160E22] border border-white/5 rounded-2xl p-8 transition-all duration-300 hover:bg-[#1F1530] hover:border-indrox-purple/15 hover:-translate-y-1 hover:shadow-[0_12px_40px_rgba(144,0,255,0.08)] before:content-[''] before:absolute before:top-0 before:left-0 before:right-0 before:h-1 before:bg-gradient-to-r before:from-indrox-purple before:to-indrox-purple-light before:opacity-0 hover:before:opacity-100 before:transition-opacity reveal">
          <div class="font-display text-5xl text-indrox-purple/10 leading-none mb-3 font-bold">{step.num}</div>
          <div class="text-4xl mb-5 block">{step.icon}</div>
          <h3 class="text-xl font-bold mb-3 text-indrox-cream tracking-[[-0.3px]]">{step.title}</h3>
