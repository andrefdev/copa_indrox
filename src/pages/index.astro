---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Navigation from "@components/astro/Navigation.astro";
import HeroSection from "@components/astro/HeroSection.astro";
import LastWinnerCard from "@components/astro/LastWinnerCard.astro";
import Podium from "@components/astro/Podium.astro";

// Fetch all content
const weeks = await getCollection("weeks");
const participants = await getCollection("participants");

// Sort weeks by date (newest first)
const sortedWeeks = weeks.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

// Get last winner
const lastWinnerWeek = sortedWeeks.find((w) => w.data.isWinner);
const lastWinnerParticipant = lastWinnerWeek
  ? await getEntry("participants", lastWinnerWeek.data.presenter.id)
  : null;
// Get top 3
const topParticipants = [...participants]
  .sort((a, b) => b.data.totalScore - a.data.totalScore)
  .slice(0, 3);
---

<BaseLayout title="Copa Indrox — Innovación con IA">
  <Navigation />

  <!-- ===== HERO ===== -->
  <HeroSection />

  <!-- ===== CÓMO FUNCIONA ===== -->
  <section
    id="como-funciona"
    class="w-full max-w-6xl mx-auto py-20 px-6 sm:px-8"
  >
    <div class="mb-14 flex flex-col items-center text-center reveal">
      <h2
        class="font-display text-[clamp(2rem,4.5vw,3.25rem)] leading-[1.1] mb-5 text-indrox-cream font-extrabold"
      >
        Cada lunes: pitches + feedback + voto
      </h2>
      <p
        class="text-indrox-cream/60 text-base leading-relaxed max-w-2xl text-center mx-auto"
      >
        Hasta 10 presentaciones de 10 minutos. Feedback directo. Al final, el equipo elige al ganador.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
      {
        [
          {
            icon: "🧠",
            title: "Idea + Claude",
            desc: "Identifica un problema. Resuélvelo con Claude.",
          },
          {
            icon: "🎤",
            title: "10 min de pitch",
            desc: "Presenta tu solución. Demo en vivo. Claro y directo.",
          },
          {
            icon: "🗳️",
            title: "Feedback + voto",
            desc: "El equipo opina. Luego vota. Ganador anunciado.",
          },
        ].map((step) => (
          <div class="bg-[#160E22] border border-white/5 rounded-2xl p-8 transition-all duration-300 hover:bg-[#1F1530] hover:border-indrox-purple/15 hover:-translate-y-1 hover:shadow-[0_12px_40px_rgba(144,0,255,0.08)] text-center reveal">
            <div class="text-4xl mb-5 block">{step.icon}</div>
            <h3 class="text-xl font-bold mb-3 text-indrox-cream">
              {step.title}
            </h3>
            <p class="text-indrox-cream/65 text-[0.95rem] leading-relaxed">
              {step.desc}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ===== CRITERIOS ===== -->
  <section id="criterios" class="w-full max-w-6xl mx-auto py-20 px-6 sm:px-8">
    <div class="mb-14 flex flex-col items-center text-center reveal">
      <div
        class="font-display text-sm tracking-[3px] text-indrox-purple-light uppercase mb-3 font-bold"
      >
        Evaluación
      </div>
      <h2
        class="font-display text-[clamp(2rem,4.5vw,3.25rem)] leading-[1.1] mb-5 text-indrox-cream font-extrabold"
      >
        ¿Cómo se elige al ganador?
      </h2>
      <p
        class="text-indrox-cream/60 text-base leading-relaxed max-w-2xl text-center mx-auto"
      >
        Tres ejes claros que todo el equipo puede evaluar. El promedio ponderado
        define al campeón semanal.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
      {
        [
          {
            icon: "💥",
            title: "Impacto",
            desc: "¿Cuánto tiempo, dinero o fricción ahorra? ¿Resuelve un problema real?",
            weight: "40%",
          },
          {
            icon: "✨",
            title: "Presentación",
            desc: "¿La landing es clara y profesional? ¿El pitch fue convincente?",
            weight: "30%",
          },
          {
            icon: "🧪",
            title: "Creatividad",
            desc: "¿Qué tan bien aprovechó las capacidades de Claude?",
            weight: "30%",
          },
        ].map((crit) => (
          <div class="bg-[#160E22] border border-white/5 rounded-2xl p-8 transition-all duration-300 hover:bg-[#1F1530] hover:border-indrox-purple/15 hover:-translate-y-1 hover:shadow-[0_12px_40px_rgba(144,0,255,0.08)] flex gap-6 items-start reveal">
            <div class="text-[2.5rem] shrink-0 w-16 h-16 flex items-center justify-center bg-indrox-purple/10 rounded-2xl border border-indrox-purple/15">
              {crit.icon}
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2 text-indrox-cream tracking-[[-0.3px]]">
                {crit.title}
              </h3>
              <p class="text-indrox-cream/65 text-[0.95rem] leading-relaxed">
                {crit.desc}
              </p>
              <span class="inline-block font-display text-xs tracking-wide text-indrox-purple-light bg-indrox-purple/10 px-3 py-1.5 rounded-lg mt-3 font-semibold border border-indrox-purple/20">
                {crit.weight} del puntaje
              </span>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ===== TIMELINE ===== -->
  <section class="w-full max-w-6xl mx-auto py-20 px-6 sm:px-8">
    <div class="mb-14 flex flex-col items-center text-center reveal">
      <div
        class="font-display text-sm tracking-[3px] text-indrox-purple-light uppercase mb-3 font-bold"
      >
        Cada lunes
      </div>
      <h2
        class="font-display text-[clamp(2rem,4.5vw,3.25rem)] leading-[1.1] mb-5 text-indrox-cream font-extrabold"
      >
        El formato
      </h2>
      <p
        class="text-indrox-cream/60 text-base leading-relaxed max-w-2xl text-center mx-auto"
      >
        Rápido, concreto y tipo demo day. Nadie se aburre, todos aprenden.
      </p>
    </div>

    <div
      class="flex flex-col md:flex-row items-stretch gap-0 mt-12 rounded-2xl overflow-hidden border border-white/10 reveal"
    >
      <div
        class="flex-1 py-10 px-5 text-center bg-[#160E22] border-b md:border-b-0 md:border-r border-white/5 last:border-0 transition-all duration-300 hover:bg-[#1F1530] hover:-translate-y-0.5"
      >
        <div class="text-[1.75rem] mb-3 block">🎤</div>
        <div
          class="font-display text-[1.35rem] text-indrox-purple-light mb-2 font-bold"
        >
          10:00–11:40
        </div>
        <div
          class="text-[0.85rem] text-indrox-cream/60 leading-relaxed font-medium"
        >
          Hasta 10 ponentes × 10 min
        </div>
      </div>
      <div
        class="flex-1 py-10 px-5 text-center bg-[#160E22] border-b md:border-b-0 md:border-r border-white/5 last:border-0 transition-all duration-300 hover:bg-[#1F1530] hover:-translate-y-0.5"
      >
        <div class="text-[1.75rem] mb-3 block">💬</div>
        <div
          class="font-display text-[1.35rem] text-indrox-purple-light mb-2 font-bold"
        >
          Durante
        </div>
        <div
          class="text-[0.85rem] text-indrox-cream/60 leading-relaxed font-medium"
        >
          Feedback tras cada pitch
        </div>
      </div>
      <div
        class="flex-1 py-10 px-5 text-center bg-[#160E22] border-b md:border-b-0 md:border-r border-white/5 last:border-0 transition-all duration-300 hover:bg-[#1F1530] hover:-translate-y-0.5"
      >
        <div class="text-[1.75rem] mb-3 block">🗳️</div>
        <div
          class="font-display text-[1.35rem] text-indrox-purple-light mb-2 font-bold"
        >
          11:40–11:50
        </div>
        <div
          class="text-[0.85rem] text-indrox-cream/60 leading-relaxed font-medium"
        >
          Votación y ganador
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PREMIOS ===== -->
  <section id="premios" class="w-full max-w-6xl mx-auto py-20 px-6 sm:px-8">
    <div class="mb-14 flex flex-col items-center text-center reveal">
      <div
        class="font-display text-sm tracking-[3px] text-indrox-purple-light uppercase mb-3 font-bold"
      >
        Recompensas
      </div>
      <h2
        class="font-display text-[clamp(2rem,4.5vw,3.25rem)] leading-[1.1] mb-5 text-indrox-cream font-extrabold"
      >
        ¿Qué te llevas?
      </h2>
      <p
        class="text-indrox-cream/60 text-base leading-relaxed max-w-2xl text-center mx-auto"
      >
        Tres niveles de reconocimiento. Porque las buenas ideas merecen ser
        celebradas.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
      <div
        class="relative overflow-hidden bg-[#160E22] border border-white/5 rounded-2xl p-10 transition-all duration-300 hover:bg-[#1F1530] hover:-translate-y-1 hover:shadow-[0_12px_40px_rgba(144,0,255,0.08)] !border-t-4 !border-t-indrox-purple-light reveal"
      >
        <div class="text-[3rem] mb-5 block">🏆</div>
        <h3
          class="font-display text-[1.7rem] tracking-[0.5px] mb-2 text-indrox-cream font-bold"
        >
          Ganador Semanal
        </h3>
        <div
          class="text-[0.75rem] text-indrox-purple-light uppercase tracking-[1.5px] mb-6 font-semibold"
        >
          Avanza a la siguiente ronda
        </div>
        <ul class="list-none flex flex-col gap-3 m-0 p-0 text-left">
          <li
            class="text-indrox-cream/65 text-[0.95rem] pl-7 relative leading-relaxed before:content-['→'] before:absolute before:left-0 before:text-indrox-purple-light before:font-bold"
          >
            Clasificación a Ganador Mensual
          </li>
          <li
            class="text-indrox-cream/65 text-[0.95rem] pl-7 relative leading-relaxed before:content-['→'] before:absolute before:left-0 before:text-indrox-purple-light before:font-bold"
          >
            Perfil destacado en la web
          </li>
          <li
            class="text-indrox-cream/65 text-[0.95rem] pl-7 relative leading-relaxed before:content-['→'] before:absolute before:left-0 before:text-indrox-purple-light before:font-bold"
          >
            Reconocimiento público
          </li>
        </ul>
      </div>

      <div
        class="relative overflow-hidden bg-gradient-to-b from-[#FFD700]/10 to-[#160E22] via-[40%] border border-white/5 rounded-2xl p-10 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_12px_40px_rgba(255,215,0,0.15)] !border-t-4 !border-t-[#FFD700] reveal"
      >
        <div class="text-[3rem] mb-5 block">💰</div>
        <h3
          class="font-display text-[1.7rem] tracking-[0.5px] mb-2 text-indrox-cream font-bold"
        >
          Campeón Mensual
        </h3>
        <div
          class="text-[0.75rem] text-[#FFD700] uppercase tracking-[1.5px] mb-6 font-semibold"
        >
          La idea con mejor desempeño
        </div>
        <ul class="list-none flex flex-col gap-3 m-0 p-0 text-left">
          <li
            class="text-indrox-cream/65 text-[0.95rem] pl-7 relative leading-relaxed before:content-['→'] before:absolute before:left-0 before:text-[#FFD700] before:font-bold"
          >
            $100 USD
          </li>
          <li
            class="text-indrox-cream/65 text-[0.95rem] pl-7 relative leading-relaxed before:content-['→'] before:absolute before:left-0 before:text-[#FFD700] before:font-bold"
          >
            Perfil destacado con badge especial
          </li>
          <li
            class="text-indrox-cream/65 text-[0.95rem] pl-7 relative leading-relaxed before:content-['→'] before:absolute before:left-0 before:text-[#FFD700] before:font-bold"
          >
            Opción de fase de producto
          </li>
        </ul>
      </div>

      <div
        class="relative overflow-hidden bg-gradient-to-b from-indrox-purple/15 to-[#160E22] border border-white/5 rounded-2xl p-10 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_12px_40px_rgba(144,0,255,0.08)] !border-t-4 !border-t-indrox-purple reveal"
      >
        <div class="text-[3rem] mb-5 block">🚀</div>
        <h3
          class="font-display text-[1.7rem] tracking-[0.5px] mb-2 text-indrox-cream font-bold"
        >
          Fase de Producto
        </h3>
        <div
          class="text-[0.75rem] text-indrox-purple-light uppercase tracking-[1.5px] mb-6 font-semibold"
        >
          Si la idea se vende
        </div>
        <ul class="list-none flex flex-col gap-3 m-0 p-0 text-left">
          <li
            class="text-indrox-cream/65 text-[0.95rem] pl-7 relative leading-relaxed before:content-['→'] before:absolute before:left-0 before:text-indrox-purple-light before:font-bold"
          >
            % de ganancias (a definir)
          </li>
          <li
            class="text-indrox-cream/65 text-[0.95rem] pl-7 relative leading-relaxed before:content-['→'] before:absolute before:left-0 before:text-indrox-purple-light before:font-bold"
          >
            Rol en desarrollo y estrategia
          </li>
          <li
            class="text-indrox-cream/65 text-[0.95rem] pl-7 relative leading-relaxed before:content-['→'] before:absolute before:left-0 before:text-indrox-purple-light before:font-bold"
          >
            Participación en crecimiento
          </li>
        </ul>
      </div>
    </div>
  </section>


  <!-- ===== GANADOR ACTUAL ===== -->
  {
    lastWinnerParticipant && lastWinnerWeek && (
      <LastWinnerCard
        presenterName={lastWinnerParticipant.data.name}
        presenterRole={lastWinnerParticipant.data.role}
        presenterPhoto={lastWinnerParticipant.data.photo}
        projectTitle={lastWinnerWeek.data.projectTitle}
        totalScore={lastWinnerWeek.data.totalScore}
        landingUrl={lastWinnerWeek.data.landingUrl}
      />
    )
  }

  <!-- ===== PODIUM ===== -->
  {
    topParticipants.length === 3 && (
      <Podium
        first={{
          name: topParticipants[0].data.name,
          score: topParticipants[0].data.totalScore,
          photo: topParticipants[0].data.photo,
          slug: topParticipants[0].id,
        }}
        second={{
          name: topParticipants[1].data.name,
          score: topParticipants[1].data.totalScore,
          photo: topParticipants[1].data.photo,
          slug: topParticipants[1].id,
        }}
        third={{
          name: topParticipants[2].data.name,
          score: topParticipants[2].data.totalScore,
          photo: topParticipants[2].data.photo,
          slug: topParticipants[2].id,
        }}
      />
    )
  }

  <!-- ===== CTA FINAL ===== -->
  <div
    class="text-center py-24 px-6 relative before:content-[''] before:absolute before:inset-0 before:bg-[radial-gradient(ellipse_500px_300px_at_50%_50%,rgba(144,0,255,0.08)_0%,transparent_70%)] before:pointer-events-none before:z-0"
  >
    <div class="relative z-10 max-w-[700px] mx-auto reveal">
      <div class="text-[4rem] mb-6 block">⚡</div>
      <h2
        class="font-display text-[clamp(2rem,4.5vw,3.25rem)] leading-[1.1] mb-5 text-indrox-cream font-extrabold"
      >
        ¿Tienes una idea?<br />El próximo lunes es tuyo.
      </h2>
      <p
        class="text-indrox-cream/65 text-base leading-relaxed max-w-2xl text-center mx-auto mb-10"
      >
        No necesitas ser programador. No necesitas permiso. Solo necesitas ver
        un problema y atreverte a resolverlo.
      </p>
      <a
        href="/hall-of-fame"
        class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-full font-body text-[0.95rem] font-semibold text-white no-underline transition-all duration-300 bg-gradient-to-br from-indrox-purple to-indrox-purple-dark shadow-[0_4px_20px_rgba(144,0,255,0.3)] hover:-translate-y-0.5 hover:shadow-[0_8px_32px_rgba(144,0,255,0.45)] w-full sm:w-auto"
      >
        Ver Hall of Fame →
      </a>
    </div>
  </div>

  <!-- ===== FOOTER ===== -->
  <footer
    class="text-center py-12 px-6 text-indrox-cream/50 text-[0.85rem] border-t border-white/10"
  >
    <p>
      <span class="text-indrox-purple-light font-bold">Copa Indrox</span> — Innovación
      impulsada por el equipo · Temporada 2026
    </p>
    <p class="mt-2 opacity-70">
      Construido con Claude como ejemplo de lo que puedes hacer tú.
    </p>
  </footer>
</BaseLayout>

<script>
  // Scroll reveal animation
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
  );

  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));

  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach((a) => {
    a.addEventListener("click", (e) => {
      e.preventDefault();
      const href = a.getAttribute("href");
      if (!href) return;
      const target = document.querySelector(href);
      if (target) target.scrollIntoView({ behavior: "smooth" });
    });
  });
</script>
